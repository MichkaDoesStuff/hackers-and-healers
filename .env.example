# Copy to .env and fill in. The system runs with NO key (deterministic draft fallback).

# FHIR server (HAPI)
FHIR_BASE=http://localhost:8080/fhir

# LLM provider for drafting. fallback = no key needed.
LLM_PROVIDER=fallback             # anthropic | openai | fallback
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Detection thresholds (days)
ABNORMAL_UNACKED_DAYS=7
ORDERED_NOT_RESULTED_DAYS=14
REFERRAL_NO_RESPONSE_DAYS=10

# Frontend -> backend base (set in patient-workflow-visualization/.env.local)
# NEXT_PUBLIC_API_BASE=http://localhost:8010

# Copy to .env and fill in. The system runs with NO key (deterministic draft fallback).

# FHIR server (HAPI)
FHIR_BASE=http://localhost:8080/fhir

# LLM provider for drafting. fallback = no key needed.
LLM_PROVIDER=vertex              # vertex | anthropic | openai | fallback
GOOGLE_CLOUD_PROJECT=project-0a4fffd1-40be-4d34-9a9
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Detection thresholds (days)
ABNORMAL_UNACKED_DAYS=7
ORDERED_NOT_RESULTED_DAYS=14
REFERRAL_NO_RESPONSE_DAYS=10

# Twilio Programmable Voice — outbound AI call that phones patients to book.
# With no SID/token/number (or no PUBLIC_BASE_URL) the call is SIMULATED locally
# and a slot is auto-booked so the workflow still runs end-to-end.
# These can live in the repo-root .env (loaded automatically) or here.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=          # your Twilio voice number, E.164 e.g. +14165551234
# Public URL that fronts this app so Twilio can reach our TwiML webhooks
# (/api/voice/*). Usually your Cloudflare tunnel, e.g. https://<id>.trycloudflare.com
PUBLIC_BASE_URL=

# Calendar: optional generic webhook for booked visits (Google/Outlook/clinic
# scheduler). Empty = local "custom calendar" store only (each visit exposes an .ics).
CALENDAR_WEBHOOK_URL=
CLINIC_TIMEZONE=America/Toronto

# Frontend -> backend base (set in patient-workflow-visualization/.env.local)
# NEXT_PUBLIC_API_BASE=http://localhost:8010
